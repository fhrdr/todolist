* {
    font-family: "Microsoft YaHei UI", "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #f8fafc;
}

QTabWidget::pane {
    border: none;
    background-color: #f8fafc;
}

QTabWidget::tab-bar {
    left: 16px;
}

QTabBar::tab {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 12px 24px;
    margin-right: 4px;
    color: #64748b;
    font-weight: 500;
}

QTabBar::tab:selected {
    color: #3b82f6;
    border-bottom: 2px solid #3b82f6;
}

QTabBar::tab:hover:!selected {
    color: #3b82f6;
    background-color: rgba(59, 130, 246, 0.05);
}

QPushButton {
    background-color: #3b82f6;
    border: none;
    border-radius: 6px;
    color: #ffffff;
    padding: 8px 16px;
    font-weight: 500;
    min-width: 70px;
}

QPushButton:hover {
    background-color: #2563eb;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

QPushButton:disabled {
    background-color: #cbd5e1;
    color: #94a3b8;
}

QPushButton#deleteBtn {
    background-color: #ef4444;
}

QPushButton#deleteBtn:hover {
    background-color: #dc2626;
}

QPushButton#deleteBtn:pressed {
    background-color: #b91c1c;
}

QPushButton#syncBtn {
    background-color: #8b5cf6;
}

QPushButton#syncBtn:hover {
    background-color: #7c3aed;
}

QPushButton#newFolderBtn, QPushButton#newTodoBtn {
    background-color: #10b981;
}

QPushButton#newFolderBtn:hover, QPushButton#newTodoBtn:hover {
    background-color: #059669;
}

QPushButton#deleteFolderBtn {
    background-color: #f59e0b;
}

QPushButton#deleteFolderBtn:hover {
    background-color: #d97706;
}

QPushButton#deleteFolderBtn:disabled {
    background-color: #cbd5e1;
}

QPushButton#pinFolderBtn {
    background-color: #6366f1;
}

QPushButton#pinFolderBtn:hover {
    background-color: #4f46e5;
}

QListWidget {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    outline: none;
    padding: 4px;
}

QListWidget::item {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    margin: 2px 4px;
    color: #334155;
}

QListWidget::item:hover {
    background-color: #f1f5f9;
    color: #334155;
}

QListWidget::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}

QListWidget::item:selected:hover {
    background-color: #bfdbfe;
    color: #1e40af;
}

QLineEdit {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #ffffff;
    color: #334155;
    selection-background-color: #bfdbfe;
    selection-color: #1e40af;
}

QLineEdit:focus {
    border-color: #3b82f6;
    background-color: #ffffff;
}

QLineEdit:disabled {
    background-color: #f8fafc;
    color: #94a3b8;
}

QLineEdit::placeholder {
    color: #94a3b8;
}

QTextEdit {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px;
    background-color: #ffffff;
    color: #334155;
    selection-background-color: #bfdbfe;
    selection-color: #1e40af;
}

QTextEdit:focus {
    border-color: #3b82f6;
}

QTextEdit:disabled {
    background-color: #f8fafc;
    color: #94a3b8;
}

QCheckBox {
    spacing: 8px;
    color: #334155;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #cbd5e1;
    background-color: #ffffff;
}

QCheckBox::indicator:hover {
    border-color: #3b82f6;
}

QCheckBox::indicator:checked {
    background-color: #3b82f6;
    border-color: #3b82f6;
    image: url(data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbj0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciPjxwYXRoIGQ9Ik0xMCAzTDQuNSA4LjVMMiA2IiBzdHJva2U9IndoaXRlIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCIvPjwvc3ZnPg==);
}

QCheckBox::indicator:disabled {
    background-color: #f1f5f9;
    border-color: #e2e8f0;
}

QLabel {
    color: #334155;
    background-color: transparent;
}

QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

QScrollBar:vertical {
    background-color: #f1f5f9;
    width: 8px;
    border-radius: 4px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #cbd5e1;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #94a3b8;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background-color: #f1f5f9;
    height: 8px;
    border-radius: 4px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #cbd5e1;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #94a3b8;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

QSplitter::handle {
    background-color: #e2e8f0;
}

QSplitter::handle:horizontal {
    width: 1px;
}

QSplitter::handle:vertical {
    height: 1px;
}

QToolTip {
    background-color: #1e293b;
    color: #f8fafc;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 12px;
}

QMenu {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 4px;
}

QMenu::item {
    padding: 8px 24px 8px 12px;
    border-radius: 4px;
    color: #334155;
}

QMenu::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}

QMenu::separator {
    height: 1px;
    background-color: #e2e8f0;
    margin: 4px 8px;
}

QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #e2e8f0;
    color: #64748b;
    padding: 4px 12px;
}

QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 2px;
}

QMenuBar::item {
    padding: 6px 12px;
    border-radius: 4px;
    color: #334155;
}

QMenuBar::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}

QCalendarWidget {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #3b82f6;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}

QCalendarWidget QToolButton {
    color: #ffffff;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 4px;
}

QCalendarWidget QToolButton:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

QCalendarWidget QToolButton::menu-indicator {
    image: none;
}

QCalendarWidget QTableView {
    background-color: #ffffff;
    selection-background-color: #dbeafe;
    selection-color: #1e40af;
    gridline-color: #f1f5f9;
    outline: none;
}

QCalendarWidget QTableView::item {
    padding: 4px;
    border-radius: 4px;
    color: #334155;
}

QCalendarWidget QTableView::item:hover {
    background-color: #f1f5f9;
}

QCalendarWidget QTableView::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}

QCalendarWidget QSpinBox {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 4px 8px;
    color: #334155;
}

QCalendarWidget QMenu {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

QComboBox {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #ffffff;
    color: #334155;
    min-width: 100px;
}

QComboBox:hover {
    border-color: #3b82f6;
}

QComboBox:focus {
    border-color: #3b82f6;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #64748b;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    selection-background-color: #dbeafe;
    selection-color: #1e40af;
    padding: 4px;
}

QComboBox QAbstractItemView::item {
    padding: 8px 12px;
    border-radius: 4px;
    color: #334155;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #f1f5f9;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #dbeafe;
    color: #1e40af;
}

QSpinBox {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #ffffff;
    color: #334155;
    selection-background-color: #dbeafe;
    selection-color: #1e40af;
}

QSpinBox:hover {
    border-color: #3b82f6;
}

QSpinBox:focus {
    border-color: #3b82f6;
}

QSpinBox::up-button, QSpinBox::down-button {
    background-color: transparent;
    border: none;
    width: 20px;
}

QSpinBox::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 6px solid #64748b;
}

QSpinBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #64748b;
}

QDateEdit {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #ffffff;
    color: #334155;
}

QDateEdit:hover {
    border-color: #3b82f6;
}

QDateEdit:focus {
    border-color: #3b82f6;
}

QDateEdit::drop-down {
    border: none;
    width: 24px;
}

QDateEdit::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #64748b;
}

QDateEdit::calendar-popup {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

QPushButton#addTagBtn {
    background-color: #e0e7ff;
    border: none;
    border-radius: 12px;
    color: #4f46e5;
    font-weight: bold;
    font-size: 14px;
    min-width: 24px;
    max-width: 24px;
    padding: 0px;
}

QPushButton#addTagBtn:hover {
    background-color: #c7d2fe;
}

QPushButton#addTagBtn:pressed {
    background-color: #a5b4fc;
}

QPushButton#addTagBtn:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
}

QScrollArea#detailScrollArea {
    border: none;
    background-color: transparent;
}

QWidget#detailContent {
    background-color: transparent;
}
